UnLitGeneric
{
	$basetexture 			"models\weapons\v_models\status\stat_digit"
	$basealphaenvmapmask 	"1"
	$envmap 				"env_cubemap"
	$envmaptint				"[0.2 0.2 0.2]"
	Proxies
	{
		AnimatedTexture
		{
			animatedtexturevar			$basetexture
			animatedtextureframenumvar	$frame
			animatedtextureframerate	0.3
		}
		StatTrakIllum
		{
			resultVar	$color
			minVal		0.7
			maxVal		1.2
		}
	}
}